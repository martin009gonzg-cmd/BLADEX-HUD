button(pgLucky,"Comprar Mejor Luckyblock",function()
    if not LB.BuySkin then notify("BLADEX Lucky","Remote BuySkin no encontrado",4); return end
    local skins={
        "prestige_mogging_luckyblock","mogging_luckyblock","colossus _luckyblock",
        "inferno_luckyblock","divine_luckyblock","spirit_luckyblock",
        "cyborg_luckyblock","void_luckyblock","gliched_luckyblock",
        "lava_luckyblock","freezy_luckyblock","fairy_luckyblock"
    }
    local gui = lp.PlayerGui:FindFirstChild("Windows")
    local sf = gui and gui:FindFirstChild("PickaxeShop") and
        gui.PickaxeShop:FindFirstChild("ShopContainer") and
        gui.PickaxeShop.ShopContainer:FindFirstChild("ScrollingFrame")
    if not sf then notify("BLADEX Lucky","GUI de tienda no encontrada",4); return end
    local ls = lp:FindFirstChild("leaderstats")
    local cash = ls and ls:FindFirstChild("Cash") and ls.Cash.Value or 0
    local bestSkin,bestPrice=nil,0
    local suffix={K=1e3,M=1e6,B=1e9,T=1e12,Qa=1e15,Qi=1e18}
    local function parseCash(t)
        t=t:gsub("%$",""):gsub(",",""):gsub("%s+","")
        local n=tonumber(t:match("[%d%.]+"))
        local s=t:match("%a+")
        if not n then return 0 end
        if s and suffix[s] then return n*suffix[s] end
        return n
    end
    for _,name in ipairs(skins) do
        local item=sf:FindFirstChild(name)
        if item then
            local bb=item:FindFirstChild("Main") and item.Main:FindFirstChild("Buy") and item.Main.Buy:FindFirstChild("BuyButton")
            if bb and bb.Visible then
                local cl=bb:FindFirstChild("Cash")
                if cl then
                    local price=parseCash(cl.Text)
                    if cash>=price and price>bestPrice then bestSkin=name; bestPrice=price end
                end
            end
        end
    end
    if bestSkin then
        safeInvoke(LB.BuySkin,bestSkin)
        notify("BLADEX Lucky","Comprado: "..bestSkin,3)
    else
        notify("BLADEX Lucky","No hay skin disponible con tu cash",4)
    end
end)

button(pgLucky,"Recoger Todos los Brainrots",function()
    local plots = workspace:FindFirstChild("Plots")
    if not plots then return end
    local myPlot = nil
    for i=1,5 do
        local p=plots:FindFirstChild(tostring(i))
        if p and p:FindFirstChild(tostring(i)) then
            local inner=p[tostring(i)]
            for _,v in pairs(inner:GetDescendants()) do
                if v:IsA("BillboardGui") and v.Name:find(lp.Name) then myPlot=inner; break end
            end
        end
        if myPlot then break end
    end
    if not myPlot then notify("BLADEX Lucky","Tu plot no encontrado",4); return end
    local containers=myPlot:FindFirstChild("Containers")
    if not containers then return end
    for i=1,30 do
        local cf=containers:FindFirstChild(tostring(i))
        if cf and cf:FindFirstChild(tostring(i)) then
            local cont=cf[tostring(i)]
            local im=cont:FindFirstChild("InnerModel")
            if im and #im:GetChildren()>0 then
                if LB.PickupBrainrot then LB.PickupBrainrot:InvokeServer(tostring(i)) end
                task.wait(0.1)
            end
        end
    end
    notify("BLADEX Lucky","Brainrots recogidos",3)
end)

