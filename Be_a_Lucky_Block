local function safeInvoke(remote,...)
    if not remote then return false end
    local ok,res = pcall(remote.InvokeServer, remote, ...)
    return ok,res
end

local function getMyModel()
    local folder = workspace:FindFirstChild("RunningModels")
    if not folder then return nil end
    for _,model in ipairs(folder:GetChildren()) do
        if model:GetAttribute("OwnerId") == lp.UserId then return model end
    end
    return nil
end

local function setModelCF(model, cf)
    if model.PrimaryPart then model:SetPrimaryPartCFrame(cf)
    else
        local p = model:FindFirstChildWhichIsA("BasePart")
        if p then p.CFrame = cf end
    end
end

