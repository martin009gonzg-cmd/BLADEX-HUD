-- ================================================
local Plots         = workspace:WaitForChild("Plots")
local HEIGHT_OFFSET = 3

local function findMyPlot()
    for _, m in ipairs(Plots:GetChildren()) do
        if m:GetAttribute("Owner") == lp.UserId then return m end
    end
end

local function getBaseCFrame()
    local plot = findMyPlot()
    if not plot then return nil end
    local ok, cf, size = pcall(function() return plot:GetBoundingBox() end)
    if ok and cf then
        local floorY   = cf.Position.Y - size.Y / 2 + HEIGHT_OFFSET
        local frontPos = cf.Position - cf.LookVector * (size.Z / 2 + 8)
        return CFrame.new(
            Vector3.new(frontPos.X, floorY, frontPos.Z),
            Vector3.new(cf.Position.X, floorY, cf.Position.Z)
        )
    end
    for _, v in ipairs(plot:GetDescendants()) do
        if v:IsA("BasePart") then
            return v.CFrame + Vector3.new(0, HEIGHT_OFFSET, 0)
        end
    end
end

local function teleportToBase(root)
    local cf = getBaseCFrame()
    if cf and root then root.CFrame = cf end
end

