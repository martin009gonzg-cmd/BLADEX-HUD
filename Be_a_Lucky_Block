-- ==================== HELPERS ====================
local function safeInvoke(remote, ...)
    if not remote then return false, "Remoto nulo" end
    local ok, res = pcall(remote.InvokeServer, remote, ...)
    if not ok then warn("[safeInvoke] " .. tostring(res)) end
    return ok, res
end

local activeThreads = {}
local function startLoop(name, fn)
    if activeThreads[name] then pcall(task.cancel, activeThreads[name]) activeThreads[name] = nil end
    activeThreads[name] = task.spawn(fn)
end
local function stopLoop(name)
    if activeThreads[name] then pcall(task.cancel, activeThreads[name]) activeThreads[name] = nil end
end

local suffix = { K=1e3,M=1e6,B=1e9,T=1e12,Qa=1e15,Qi=1e18,Sx=1e21,Sp=1e24,Oc=1e27,No=1e30,Dc=1e33 }
local function parseCash(text)
    text = text:gsub("%$",""):gsub(",",""):gsub("%s+","")
    local num = tonumber(text:match("[%d%.]+"))
    local suf = text:match("%a+")
    if not num then return 0 end
    if suf and suffix[suf] then return num * suffix[suf] end
    return num
end

