local function tryFirePrompt(prompt)
    pcall(function() prompt.MaxActivationDistance=32 end)
    pcall(function() prompt.HoldDuration=0 end)
    local ok = pcall(fireproximityprompt, prompt)
    if ok then return true end
    ok = pcall(function() game:GetService("ProximityPromptService"):FirePrompt(prompt) end)
    if ok then return true end
    ok = pcall(function() prompt:InputHoldBegin(); task.wait(0.05); prompt:InputHoldEnd() end)
    return ok
end

local function getBrainrotPrompts()
    local result = {}
    local folder = workspace:FindFirstChild("Brainrots")
    if not folder then return result end
    for _, brainrot in ipairs(folder:GetChildren()) do
        local rarity = brainrot:GetAttribute("Rarity")
        if not rarity then
            local rv = brainrot:FindFirstChild("Rarity")
            if rv then rarity = tostring(rv.Value) end
        end
        if not rarity then rarity = "Common" end
        local permitido = state.rarityFilter[rarity]
        if permitido == nil then permitido = true end
        if permitido then
            for _, desc in ipairs(brainrot:GetDescendants()) do
                if desc:IsA("ProximityPrompt") and desc.ActionText == "Carry" then
                    local part = desc.Parent
                    if part and part:IsA("BasePart") then
                        table.insert(result,{prompt=desc,part=part,rarity=rarity,
                            model=brainrot,index=brainrot:GetAttribute("Index") or brainrot.Name or "?"})
                        break
                    end
                end
            end
        end
    end
    return result
end

local function getPlayerCash()
    local ls = lp:FindFirstChild("leaderstats")
    if ls then local c=ls:FindFirstChild("Cash"); if c then return tostring(c.Value) end end
    return "?"
end

local function getClaimPrompts()
    local result,plot={},findMyPlot()
    if not plot then return result end
    for _,desc in ipairs(plot:GetDescendants()) do
        if desc:IsA("ProximityPrompt") and desc.ActionText=="Claim" then
            local part=desc.Parent
            if part and part:IsA("BasePart") then
                table.insert(result,{prompt=desc,part=part,
                    label=desc.ObjectText~="" and desc.ObjectText or "Claim"})
            end
        end
    end
    return result
end

local function getUpgradePrompts()
    local result,plot={},findMyPlot()
    if not plot then return result end
    for _,desc in ipairs(plot:GetDescendants()) do
        if desc:IsA("ProximityPrompt") and desc.ActionText=="Purchase" then
            local part=desc.Parent
            if part and part:IsA("BasePart") then
                table.insert(result,{prompt=desc,part=part,
                    label=desc.ObjectText~="" and desc.ObjectText or "Purchase"})
            end
        end
    end
    return result
end

