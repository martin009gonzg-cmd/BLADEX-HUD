local tabs     = {}
local tabOrder = 0
local activeTab= nil

local TAB_ICONS = {Farm="🌾",Economy="💰",Player="⚡",Stats="📊",Config="⚙️",Lucky="🍀"}

-- switchTab: función directa — NO depende de Fire()
local function switchTab(name)
    if activeTab==name then return end
    activeTab=name
    for tname,t in pairs(tabs) do
        local isActive=(tname==name)
        for _,item in ipairs(t.items) do item.Visible=isActive end
        TweenService:Create(t.btn,TweenInfo.new(0.15),{
            BackgroundColor3=isActive and ACCENT or Color3.fromRGB(20,20,28),
            TextColor3=isActive and Color3.fromRGB(255,255,255) or Color3.fromRGB(115,115,138),
        }):Play()
        if t.ind then
            TweenService:Create(t.ind,TweenInfo.new(0.15),{
                BackgroundTransparency=isActive and 0 or 1,
            }):Play()
        end
    end
    scroll.CanvasPosition=Vector2.new(0,0)
end

local function newTab(name)
    tabOrder+=1
    local icon=TAB_ICONS[name] or ""
    local btn=make("TextButton",{
        Size=UDim2.new(1,0,0,46),
        BackgroundColor3=Color3.fromRGB(20,20,28),
        Text=icon.."\n"..name,
        TextColor3=Color3.fromRGB(115,115,138),
        Font=Enum.Font.GothamBold,TextSize=9,
        BorderSizePixel=0,LayoutOrder=tabOrder,
        AutoButtonColor=false,LineHeight=1.3,
    },sidebar)
    corner(8,btn)

    -- Indicador accent derecho
    local ind=make("Frame",{
        Size=UDim2.new(0,3,0.5,0),Position=UDim2.new(1,-3,0.25,0),
        BackgroundColor3=ACCENT,BackgroundTransparency=1,BorderSizePixel=0},btn)
    corner(2,ind)

    local items={}
    tabs[name]={btn=btn,items=items,ind=ind}
    btn.Activated:Connect(function() switchTab(name) end)
    return items
end

