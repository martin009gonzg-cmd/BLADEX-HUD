-- ==================== BOSS FARM (misma lógica que Brainrots) ====================
local function runBossFarmLoop(bossName, activeFlag)
    local bossCoords = BASE_COORDS[bossName]
    if not bossCoords then
        warn("[BLADEX] Coords no encontradas para " .. bossName)
        return
    end

    local teleportPos = bossCoords.block.Position
    local movePos     = bossCoords.block.Position + Vector3.new(-4, 0, 0)
    local respawnPos  = bossCoords.runner.Position
    local runCount    = 0

    while _G[activeFlag] do
        local character    = LP.Character or LP.CharacterAdded:Wait()
        local root         = character:WaitForChild("HumanoidRootPart")
        local humanoid     = character:WaitForChild("Humanoid")
        local userId       = LP.UserId
        local modelsFolder = workspace:WaitForChild("RunningModels")
        local collectZones = workspace:WaitForChild("CollectZones")
        local target       = collectZones:FindFirstChild(bossName)
        local targetCF     = target and target.CFrame or bossCoords.block

        -- 1. Teleport al bloque boss
        root.CFrame = CFrame.new(teleportPos)
        task.wait(0.3)
        humanoid:MoveTo(movePos)

        -- 2. Esperar modelo propio
        local ownedModel = nil
        local deadline   = tick() + 10
        repeat
            task.wait(0.3)
            for _, obj in ipairs(modelsFolder:GetChildren()) do
                if obj:IsA("Model") and obj:GetAttribute("OwnerId") == userId then
                    ownedModel = obj
                    break
                end
            end
        until ownedModel ~= nil or not _G[activeFlag] or tick() > deadline
        if not _G[activeFlag] then break end

        -- 3. Mover modelo a zona de colecta
        if ownedModel then
            setModelCFrame(ownedModel, targetCF)
            task.wait(0.7)

            if ownedModel and ownedModel.Parent == modelsFolder then
                setModelCFrame(ownedModel, targetCF * CFrame.new(0, -5, 0))
            end

            -- 4. Esperar muerte del modelo
            repeat task.wait(0.3) until not _G[activeFlag]
                or (ownedModel == nil or ownedModel.Parent ~= modelsFolder)
            if not _G[activeFlag] then break end
        end

        -- 5. Esperar respawn del personaje
        local oldChar = LP.Character
        repeat task.wait(0.2) until not _G[activeFlag]
            or (LP.Character ~= oldChar and LP.Character ~= nil)
        if not _G[activeFlag] then break end

        -- 6. Tp al spawn del boss y esperar
        task.wait(0.4)
        LP.Character:WaitForChild("HumanoidRootPart").CFrame = CFrame.new(respawnPos)
        task.wait(2.1)

        runCount = runCount + 1
        print("[BLADEX] " .. bossName .. " Run #" .. runCount .. " completado.")
    end
end

local function loopAutoZeusFarm()
    runBossFarmLoop("ZEUS", "AutoZeus")
end

local function loopAutoDevilFarm()
