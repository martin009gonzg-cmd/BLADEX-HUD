                    if not runningFarm then break end

                    task.wait(0.4)
                    LP.Character:WaitForChild("HumanoidRootPart").CFrame = CFrame.new(currentBase.respawn)
                    task.wait(2.1)

                    farmRunCount  = farmRunCount + 1
                    farmBaseIndex = (farmBaseIndex % #bases) + 1
                    print("[BLADEX] Run #" .. farmRunCount .. " completado en " .. currentBase.name)
                end
            end)
        end
    end
})

