                                local ok=tryFirePrompt(entry.prompt)
                                if not ok then
                                    task.wait(0.12)
                                    r.CFrame=entry.part.CFrame+Vector3.new(0,2.5,0)
                                    task.wait(0.1); ok=tryFirePrompt(entry.prompt)
                                end
                                if ok then state.recogidos+=1 end
                                task.wait(state.farmDelay)
                                if state.retornar then teleportToBase(r); task.wait(0.25) end
                            end
                        end
                    end
                end
                task.wait(0.2)
            end
        end)
    else notify("BLADEX Farm","Auto Farm desactivado",3) end
end)
