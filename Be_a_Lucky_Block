        notify("BLADEX Farm","Auto Farm activado",3)
        task.spawn(function()
            while state.farm do
                local c=lp.Character; local r=c and c:FindFirstChild("HumanoidRootPart")
                if r then
                    local prompts=getBrainrotPrompts()
                    if #prompts==0 then task.wait(1)
                    else
                        for _,entry in ipairs(prompts) do
                            if not state.farm then break end
                            if entry.part and entry.part.Parent
                            and entry.prompt and entry.prompt.Parent
                            and entry.model and entry.model.Parent then
                                r.CFrame=entry.part.CFrame+Vector3.new(0,3,0)
