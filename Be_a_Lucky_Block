-- ── Loop principal del Lucky Block farm ───────
local function runLBFarm(baseName, activeFlag)
    local coords = LB_BASES[baseName]
    if not coords then
        notify("BLADEX Lucky","Coordenadas no encontradas: "..baseName,4); return
    end
    local blockPos  = coords.block.Position
    local movePos   = blockPos + Vector3.new(-4,0,0)
    local respawnCF = coords.respawn or CFrame.new(736.36,36.24,-2155.12)
    local collectZones = workspace:WaitForChild("CollectZones",8)
    local modelsFolder = workspace:WaitForChild("RunningModels",8)

    while state[activeFlag] do
        local c   = lp.Character or lp.CharacterAdded:Wait()
        local r   = c:WaitForChild("HumanoidRootPart")
        local hum = c:WaitForChild("Humanoid")

        -- 1. Teleportar al bloque
        r.CFrame = CFrame.new(blockPos)
        task.wait(0.3)
        hum:MoveTo(movePos)

        -- 2. Abrir Lucky Block vía remote (método UpdateCFrame + OpenLuckyBlock)
        pcall(function()
            if LB.UpdateCFrame then
                LB.UpdateCFrame:InvokeServer(CFrame.new(blockPos))
            end
        end)
        pcall(function()
            if LB.OpenLuckyBlock then
                LB.OpenLuckyBlock:InvokeServer(baseName)
            end
        end)

        -- 3. Esperar modelo propio (máx 10s)
        local ownedModel = nil
        local deadline = tick() + 10
        repeat
            task.wait(0.3)
            ownedModel = getMyModel()
        until ownedModel ~= nil or not state[activeFlag] or tick() > deadline
        if not state[activeFlag] then break end

        -- 4. Mover modelo al CollectZone
        if ownedModel then
            local target = collectZones and collectZones:FindFirstChild(baseName)
            local targetCF = target and target.CFrame or coords.runner
            setModelCF(ownedModel, targetCF)
            task.wait(0.7)
            if ownedModel.Parent == modelsFolder then
                setModelCF(ownedModel, targetCF * CFrame.new(0,-5,0))
            end
            -- 5. Esperar muerte del modelo
            repeat task.wait(0.3)
            until not state[activeFlag] or (ownedModel==nil or ownedModel.Parent~=modelsFolder)
            if not state[activeFlag] then break end
        end

        -- 6. Esperar respawn del personaje
        local oldChar = lp.Character
        repeat task.wait(0.2)
        until not state[activeFlag] or (lp.Character ~= oldChar and lp.Character ~= nil)
        if not state[activeFlag] then break end

        -- 7. Teleportar a spawn y esperar
        task.wait(0.4)
        if lp.Character then
            local hrp2 = lp.Character:FindFirstChild("HumanoidRootPart")
            if hrp2 then hrp2.CFrame = respawnCF end
        end
        task.wait(2.1)

        state.lb_runCount += 1
        print("[BLADEX LB] Run #"..state.lb_runCount.." - "..baseName)
    end
end

-- Loops de auto-features
local lbThreads = {}
local function startLBLoop(key, fn)
    if lbThreads[key] then pcall(task.cancel,lbThreads[key]) end
    lbThreads[key] = task.spawn(fn)
end
local function stopLBLoop(key)
    if lbThreads[key] then pcall(task.cancel,lbThreads[key]); lbThreads[key]=nil end
end

local function loopUpgrades()
    while state.lb_autoUpgrade do
        for i=30,1,-1 do
            if not state.lb_autoUpgrade then break end
            task.spawn(function() if LB.Brainrot then safeInvoke(LB.Brainrot,tostring(i)) end end)
            if i%5==0 then task.wait(0.01) end
        end; task.wait(0.4)
    end
end
local function loopRebirth()
    while state.lb_autoRebirth do safeInvoke(LB.Rebirth); task.wait(6) end
end
local function loopSpeedUpgrade()
    while state.lb_autoSpeed do
        for i=1,200 do
            if not state.lb_autoSpeed then break end
            task.spawn(function() safeInvoke(LB.SpeedUpgrade,"MovementSpeed",1) end)
            if i%50==0 then task.wait() end
        end; task.wait(1)
    end
end
local function loopSell()
    while state.lb_autoSell do safeInvoke(LB.SellAll); task.wait(5) end
end
local function loopCash()
    while state.lb_autoCash do
        local c2 = lp.Character
        local r2 = c2 and c2:FindFirstChild("HumanoidRootPart")
        if r2 then
            for _,v in pairs(workspace:GetDescendants()) do
                if v:IsA("BasePart") and v.Transparency < 1 then
                    if v:FindFirstChildOfClass("BillboardGui") or v:FindFirstChildOfClass("SurfaceGui") then
                        pcall(function() firetouchinterest(r2,v,0); task.wait(); firetouchinterest(r2,v,1) end)
                    end
                end
            end
        end
        task.wait(0.1)
    end
end

