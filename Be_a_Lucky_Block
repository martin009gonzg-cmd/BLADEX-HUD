-- ── Knit finder ──────────────────────────────
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local function findKnitServices()
    local ok, idx = pcall(function() return ReplicatedStorage.Packages._Index end)
    if not ok then return nil end
    for _, folder in ipairs(idx:GetChildren()) do
        if folder.Name:lower():find("knit") then
            local kf = folder:FindFirstChild("knit")
            if kf then
                local sv = kf:FindFirstChild("Services")
                if sv then return sv end
            end
        end
    end
    return nil
end

local knitSV = findKnitServices()

local function findRF(svcName, name)
    if not knitSV then return nil end
    local svc = knitSV:FindFirstChild(svcName)
    if not svc then return nil end
    local rf = svc:FindFirstChild("RF")
    return rf and rf:FindFirstChild(name)
end
local function findRE(svcName, name)
    if not knitSV then return nil end
    local svc = knitSV:FindFirstChild(svcName)
    if not svc then return nil end
    local re = svc:FindFirstChild("RE")
    return re and re:FindFirstChild(name)
end

