local function slider(pg,title,mn,mx,def,dec,cb)
    local f=make("Frame",{Size=UDim2.new(1,0,0,54),
        BackgroundColor3=Color3.fromRGB(17,17,23),BorderSizePixel=0,Visible=false},scroll)
    corner(8,f); stroke(Color3.fromRGB(36,36,50),1,0,f)
    make("TextLabel",{Size=UDim2.new(1,-62,0,20),Position=UDim2.new(0,12,0,6),
        BackgroundTransparency=1,Text=title,TextColor3=Color3.fromRGB(200,200,210),
        Font=Enum.Font.Gotham,TextSize=12,TextXAlignment=Enum.TextXAlignment.Left},f)
    local vLbl=make("TextLabel",{Size=UDim2.new(0,52,0,20),Position=UDim2.new(1,-60,0,6),
        BackgroundTransparency=1,Text=tostring(def),TextColor3=ACCENT,
        Font=Enum.Font.GothamBold,TextSize=12,TextXAlignment=Enum.TextXAlignment.Right},f)
    local track=make("Frame",{Size=UDim2.new(1,-24,0,5),Position=UDim2.new(0,12,0,37),
        BackgroundColor3=Color3.fromRGB(32,32,46),BorderSizePixel=0},f); corner(3,track)
    local fill=make("Frame",{Size=UDim2.new((def-mn)/(mx-mn),0,1,0),
        BackgroundColor3=ACCENT,BorderSizePixel=0},track); corner(3,fill)
    local sThumb=make("Frame",{Size=UDim2.new(0,13,0,13),
        Position=UDim2.new((def-mn)/(mx-mn),0,0.5,-7),
        BackgroundColor3=Color3.fromRGB(255,255,255),BorderSizePixel=0,ZIndex=3},track)
    corner(7,sThumb)
    local sliding=false
    local function upd(x)
        local r=math.clamp((x-track.AbsolutePosition.X)/track.AbsoluteSize.X,0,1)
        local v=math.floor((mn+(mx-mn)*r)*(10^dec)+0.5)/(10^dec)
        fill.Size=UDim2.new(r,0,1,0); sThumb.Position=UDim2.new(r,-7,0.5,-7)
        vLbl.Text=tostring(v); cb(v)
    end
    track.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1
        or i.UserInputType==Enum.UserInputType.Touch then sliding=true; upd(i.Position.X) end
    end)
    UIS.InputChanged:Connect(function(i)
        if not sliding then return end
        if i.UserInputType==Enum.UserInputType.MouseMovement
        or i.UserInputType==Enum.UserInputType.Touch then upd(i.Position.X) end
    end)
    UIS.InputEnded:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1
        or i.UserInputType==Enum.UserInputType.Touch then sliding=false end
    end)
    table.insert(pg,f)
end

