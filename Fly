-- =====================
-- Función para disparar remotes
-- =====================
local function fire(remote, ...)
    if type(remote) == "table" then
        if remote.Fire then
            return pcall(function() remote:Fire(...) end)
        elseif remote.InvokeServer then
            return pcall(function() remote:InvokeServer(...) end)
        elseif remote.FireServer then
            return pcall(function() remote:FireServer(...) end)
        else
            for _, v in pairs(remote) do
                if typeof(v) == "Instance" then
                    if v:IsA("RemoteEvent") then
                        return pcall(function() v:FireServer(...) end)
                    elseif v:IsA("RemoteFunction") then
                        return pcall(function() v:InvokeServer(...) end)
                    end
                end
            end
        end
    elseif typeof(remote) == "Instance" then
        if remote:IsA("RemoteEvent") then
            return pcall(function() remote:FireServer(...) end)
        elseif remote:IsA("RemoteFunction") then
            return pcall(function() remote:InvokeServer(...) end)
        end
    end
    return false
end

