})

local SecLeft  = farmTab:DrawSection({ Name = "Auto Farm",   Position = "left",  Minimized = false })
local SecRight = farmTab:DrawSection({ Name = "Auto Extras", Position = "right", Minimized = false })

SecLeft:AddToggle({
