if not Compkiller then
    warn("[BLADEX] Compkiller no encontrado. Carga la libreria antes de ejecutar este script.")
    return
end

Compkiller:OptimizeMode(true)
Compkiller:ChangeHighlightColor(Compkiller.Colors.Toggle)

local Notifier = Compkiller.newNotify()
local _BLADEX_LOADING = true

local function notify(content, duration)
    if _BLADEX_LOADING then return end
    Notifier.new({
        Title    = "BLADEX HUD",
        Content  = content,
        Duration = duration or 4,
        Icon     = Compkiller.Logo
    })
end

local ConfigManager = Compkiller:ConfigManager({
    Directory = "BLADEX-HUB",
    Config    = "BLADEX-SpearBrainrots",
})

-- === SERVICIOS ===
local Players           = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace         = game:GetService("Workspace")
local lp                = Players.LocalPlayer

-- === DELAYS ===
local DELAY_BETWEEN_SLOTS_COLLECT = 0.05
local DELAY_BETWEEN_SLOTS_PICKUP  = 0.05
local DELAY_BETWEEN_SLOTS_UPGRADE = 0.005
local CYCLE_WAIT_COLLECT          = 5
local CYCLE_WAIT_PICKUP           = 5
local CYCLE_WAIT_UPGRADE          = 0.1
local CYCLE_WAIT_BASE             = 0.5
local CYCLE_WAIT_REBIRTH          = 2
local CYCLE_WAIT_POWER            = 1
local CYCLE_WAIT_CARRY            = 2

-- === REMOTES FARM ===
local mainRemote    = ReplicatedStorage:FindFirstChild("RF/Plot.PlotAction", true)
local baseRemote    = ReplicatedStorage:FindFirstChild("RE/Plot.UpgradeBase", true)
local remFuncs      = ReplicatedStorage:FindFirstChild("RemoteFunctions", true)
local rebirthRemote = remFuncs and remFuncs:FindFirstChild("Rebirth")
local speedRemote   = remFuncs and remFuncs:FindFirstChild("UpgradeSpeed")
local carryRemote   = remFuncs and remFuncs:FindFirstChild("UpgradeCarry")

-- === UUID ===
local function detectUUID()
    for k, v in pairs(lp:GetAttributes()) do
        if type(v) == "string" and v:match("%x+%-%x+%-%x+%-%x+%-%x+") then return v end
    end
    local ls = lp:FindFirstChild("leaderstats")
    if ls then
        for _, child in ipairs(ls:GetChildren()) do
            if type(child.Value) == "string" and child.Value:match("%x+%-%x+%-%x+%-%x+%-%x+") then
                return child.Value
            end
        end
    end
    return nil
end
local currentUUID = detectUUID()

-- === ACCIONES FARM ===
local function collectSlot(slot)
    if not mainRemote or not currentUUID then return false end
    return pcall(mainRemote.InvokeServer, mainRemote, "Collect Money", currentUUID, tostring(slot))
end
local function pickupBrainrotSlot(slot)
    if not mainRemote or not currentUUID then return false end
    return pcall(mainRemote.InvokeServer, mainRemote, "Pick Up Brainrot", currentUUID, tostring(slot))
end
local function upgradeBrainrotSlot(slot)
    if not mainRemote or not currentUUID then return false end
    return pcall(mainRemote.InvokeServer, mainRemote, "Upgrade Brainrot", currentUUID, tostring(slot))
end
local function upgradeBase()
    if not baseRemote then return false end
    return pcall(baseRemote.FireServer, baseRemote)
end
local function doRebirth()
    if not rebirthRemote then return false end
    return pcall(rebirthRemote.InvokeServer, rebirthRemote)
end
local powerLevels = {10, 5, 1}
local function doPowerUpgrades()
    if not speedRemote then return false end
    for _, level in ipairs(powerLevels) do
        pcall(speedRemote.InvokeServer, speedRemote, level)
        task.wait(0.3)
    end
    return true
end
local function doCarryUpgrade()
    if not carryRemote then return false end
    return pcall(carryRemote.InvokeServer, carryRemote)
end
local function runSlots(actionFunc, delay)
    local threads = {}
    for slot = 1, 30 do
        threads[slot] = task.spawn(function() actionFunc(slot) end)
        if delay > 0 then task.wait(delay) end
    end
    for slot = 1, 30 do
        while coroutine.status(threads[slot]) ~= "dead" do task.wait() end
    end
end

-- === REMOTES SPEAR ===
local char = lp.Character or lp.CharacterAdded:Wait()
local hrp  = char:WaitForChild("HumanoidRootPart")

local throwRemote    = nil
local catchRemote    = nil
local fishBiteRemote = nil

local function deepSearch(container, depth)
    if depth > 10 then return end
    for _, obj in ipairs(container:GetChildren()) do
        if obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction") then
            if obj.Name == "ThrowSpear"  then throwRemote  = obj end
            if obj.Name == "CatchResult" then catchRemote  = obj end
        end
        deepSearch(obj, depth + 1)
    end
end
deepSearch(ReplicatedStorage, 0)
deepSearch(Workspace, 0)

for _, obj in ipairs(ReplicatedStorage:GetDescendants()) do
    if obj.Name == "FishBite" and obj:IsA("RemoteEvent") then
        fishBiteRemote = obj
        break
    end
end

-- === CONFIG SPEAR ===
local spearConfig = {
    enabled  = false,
    interval = 20,
    force     = 0.9785663485527039,
    direction = Vector3.new(1, 0, 5.116264501631423e-15),
}

local function detectSpears()
    local found = {}
    local containers = { lp.Backpack, lp.Character }
    for _, container in ipairs(containers) do
        if container then
            for _, tool in ipairs(container:GetChildren()) do
                if tool:IsA("Tool") then
                    local nameLower = tool.Name:lower()
                    if nameLower:find("spear") or nameLower:find("lanza") then
                        table.insert(found, tool.Name)
                    end
                end
            end
        end
    end
    return found
end

local function doAutoThrow()
    if not throwRemote then return end
    local spears = detectSpears()
    if #spears == 0 then return end
    for _, spearName in ipairs(spears) do
        pcall(function()
            throwRemote:FireServer(spearConfig.force, spearConfig.direction, spearName)
        end)
        task.wait(0.1)
    end
end

task.spawn(function()
    while true do
        if spearConfig.enabled then
            doAutoThrow()
            task.wait(spearConfig.interval)
        else
            task.wait(0.5)
        end
    end
end)

if fishBiteRemote then
    fishBiteRemote.OnClientEvent:Connect(function()
        if spearConfig.enabled and catchRemote then
            pcall(function() catchRemote:FireServer(true) end)
            pcall(function() catchRemote:FireServer(1)    end)
            pcall(function() catchRemote:FireServer()     end)
        end
    end)
end

-- === LOOP MANAGER ===
local activeThreads = {}
local function startLoop(name, fn)
    if activeThreads[name] then pcall(task.cancel, activeThreads[name]) activeThreads[name] = nil end
    activeThreads[name] = task.spawn(fn)
end
local function stopLoop(name)
    if activeThreads[name] then pcall(task.cancel, activeThreads[name]) activeThreads[name] = nil end
end

local function loopCollect() while true do if currentUUID then runSlots(collectSlot, DELAY_BETWEEN_SLOTS_COLLECT) end task.wait(CYCLE_WAIT_COLLECT) end end
local function loopPickup()  while true do if currentUUID then runSlots(pickupBrainrotSlot, DELAY_BETWEEN_SLOTS_PICKUP) end task.wait(CYCLE_WAIT_PICKUP) end end
local function loopUpgrade() while true do if currentUUID then runSlots(upgradeBrainrotSlot, DELAY_BETWEEN_SLOTS_UPGRADE) end task.wait(CYCLE_WAIT_UPGRADE) end end
local function loopBase()    while true do upgradeBase() task.wait(CYCLE_WAIT_BASE) end end
local function loopRebirth() while true do doRebirth() task.wait(CYCLE_WAIT_REBIRTH) end end
local function loopPower()   while true do doPowerUpgrades() task.wait(CYCLE_WAIT_POWER) end end
local function loopCarry()   while true do doCarryUpgrade() task.wait(CYCLE_WAIT_CARRY) end end

