SecLeft:AddToggle({ Name = "Auto Upgrade Brainrot", Default = false, Flag = "BLADEX_upgrade",
    Callback = function(v) if v then startLoop("Upgrade", loopUpgrade) else stopLoop("Upgrade") end end })

SecLeft:AddToggle({ Name = "Auto Rebirth", Default = false, Flag = "BLADEX_rebirth",
    Callback = function(v) if v then startLoop("Rebirth", loopRebirth) else stopLoop("Rebirth") end end })

SecLeft:AddToggle({ Name = "Auto Power Upgrades", Default = false, Flag = "BLADEX_power",
    Callback = function(v) if v then startLoop("Power", loopPower) else stopLoop("Power") end end })

SecRight:AddToggle({ Name = "Auto Upgrade Base", Default = false, Flag = "BLADEX_base",
    Callback = function(v) if v then startLoop("Base", loopBase) else stopLoop("Base") end end })

SecRight:AddToggle({ Name = "Auto Carry", Default = false, Flag = "BLADEX_carry",
    Callback = function(v) if v then startLoop("Carry", loopCarry) else stopLoop("Carry") end end })

SecRight:AddToggle({ Name = "Auto Pickup Brainrot", Default = false, Flag = "BLADEX_pickup",
    Callback = function(v) if v then startLoop("Pickup", loopPickup) else stopLoop("Pickup") end end })

Window:DrawCategory({ Name = "Misc" })

Window:DrawConfig({
    Name   = "Config",
    Icon   = "folder",
    Config = ConfigManager
}):Init()
